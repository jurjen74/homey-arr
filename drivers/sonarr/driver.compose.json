{
  "name": { "en": "Sonarr Server", "nl": "Sonarr-server" },
  "class": "other",
  "brandColor": "#00ccff",
  "images": {
    "small": "/drivers/sonarr/assets/images/small.png",
    "large": "/drivers/sonarr/assets/images/large.png"
  },
  "capabilities": [
    "alarm_generic",
    "sonarr_disk_free_gb",
    "sonarr_queue_count",
    "sonarr_missing_count",
    "sonarr_series_count",
    "sonarr_upcoming_count"
  ],
  "capabilitiesOptions": {
    "alarm_generic": {
      "title":              { "en": "Status",                      "nl": "Status" },
      "titleTrue":          { "en": "Sonarr requires attention",   "nl": "Sonarr vereist aandacht" },
      "titleFalse":         { "en": "Healthy",                     "nl": "Gezond" },
      "insightsTitleTrue":  { "en": "Sonarr requires attention",   "nl": "Sonarr vereist aandacht" },
      "insightsTitleFalse": { "en": "Sonarr is healthy",           "nl": "Sonarr is gezond" }
    }
  },
  "pair": [
    {
      "id": "connect",
      "navigation": { "next": "list_devices" }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "settings": [
    {
      "id": "host",
      "type": "text",
      "label": { "en": "Host URL", "nl": "Host-URL" },
      "value": ""
    },
    {
      "id": "apiKey",
      "type": "password",
      "label": { "en": "API Key", "nl": "API-sleutel" },
      "value": ""
    },
    {
      "id": "pollInterval",
      "type": "number",
      "label": { "en": "Poll interval (seconds)", "nl": "Pollinginterval (seconden)" },
      "value": 60,
      "min": 15,
      "max": 3600
    }
  ]
}
